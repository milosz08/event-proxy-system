{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/@types/**/*",
    "src/data/**/*",
    "src/preload/*.d.ts",
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/src/*"
      ],
      "@shared-types/*": [
        "src/@types/*"
      ],
      "@shared-data/*": [
        "src/data/*"
      ]
    }
  }
}
